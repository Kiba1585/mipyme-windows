import 'database_service.dart';

class TaxCalculation {
  final String period;
  final double grossIncome;
  final double expenses;
  final double taxableIncome;
  final double taxAmount;
  TaxCalculation({required this.period, required this.grossIncome, required this.expenses, required this.taxableIncome, required this.taxAmount});
}

class TaxService {
  static const double _incomeTaxRate = 0.05;
  static const double _salesTaxRate = 0.10;
  static const double _socialSecurityRate = 0.02;

  static TaxCalculation calculateTaxes({required String period, required double totalSales, required double totalExpenses}) {
    final utility = totalSales - totalExpenses;
    final incomeTax = utility > 0 ? utility * _incomeTaxRate : 0.0;
    final salesTax = totalSales * _salesTaxRate;
    final socialSecurity = totalSales * _socialSecurityRate;
    final totalTax = incomeTax + salesTax + socialSecurity;
    return TaxCalculation(period: period, grossIncome: totalSales, expenses: totalExpenses, taxableIncome: utility > 0 ? utility : 0, taxAmount: totalTax);
  }

  static Future<void> saveCalculation(TaxCalculation calc) async {
    await DatabaseService.saveTaxCalculation(period: calc.period, grossIncome: calc.grossIncome, expenses: calc.expenses, taxableIncome: calc.taxableIncome, taxAmount: calc.taxAmount);
  }

  static Future<List<TaxCalculation>> getHistory() async {
    final records = await DatabaseService.getTaxHistory();
    return records.map((r) => TaxCalculation(period: r['period'] as String, grossIncome: (r['gross_income'] as num).toDouble(), expenses: (r['expenses'] as num).toDouble(), taxableIncome: (r['taxable_income'] as num).toDouble(), taxAmount: (r['tax_amount'] as num).toDouble())).toList();
  }
}